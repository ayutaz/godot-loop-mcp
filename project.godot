config_version=5

[application]

config/name="godot-loop-mcp"
config/features=PackedStringArray("4.4")
config/icon="res://icon.svg"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_loop_mcp/plugin.cfg")

