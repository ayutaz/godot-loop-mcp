{
  "name": "@godot-loop-mcp/server",
  "private": true,
  "version": "0.1.0",
  "description": "Bridge server skeleton for godot-loop-mcp.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayutaz/godot-loop-mcp.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/ayutaz/godot-loop-mcp#readme",
  "bugs": {
    "url": "https://github.com/ayutaz/godot-loop-mcp/issues"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "files": [
    "README.md",
    "src/",
    "tsconfig.json"
  ],
  "scripts": {
    "start": "node --experimental-strip-types src/index.ts",
    "dev": "node --experimental-strip-types --watch src/index.ts",
    "pack": "npm pack",
    "typecheck": "tsc -p tsconfig.json",
    "smoke:m1": "node --experimental-strip-types src/dev/m1Smoke.ts",
    "smoke:m2": "node --experimental-strip-types src/dev/m2Smoke.ts",
    "smoke:m3": "node --experimental-strip-types src/dev/m3Smoke.ts",
    "smoke:m4": "node --experimental-strip-types src/dev/m4Smoke.ts",
    "smoke:m6": "node --experimental-strip-types src/dev/m6Smoke.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3"
  }
}
